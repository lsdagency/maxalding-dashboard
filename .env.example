# Database — auto-injected by Netlify DB (Neon). No need to set manually on Netlify.
# For local dev against a Postgres DB, set one of these:
# NETLIFY_DATABASE_URL=postgresql://user:password@host/dbname
# DATABASE_URL=postgresql://user:password@host/dbname

# Auth
JWT_SECRET=generate-a-long-random-string-here
ADMIN_EMAIL=you@youragency.com
ADMIN_PASSWORD=choose-a-strong-password

# Meta Ads
META_ACCESS_TOKEN=your-meta-access-token
