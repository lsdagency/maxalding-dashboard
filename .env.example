# Database — auto-filled by Railway MySQL plugin
DATABASE_URL=mysql://user:password@host:3306/dbname

# Auth
JWT_SECRET=generate-a-long-random-string-here
ADMIN_EMAIL=you@youragency.com
ADMIN_PASSWORD=choose-a-strong-password

# Meta Ads
META_ACCESS_TOKEN=your-meta-access-token

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=reports@yourdomain.com

# AI summaries (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Scheduled emails — set a random secret, use same value in Railway cron header
CRON_SECRET=generate-another-random-string-here

# Runtime
NODE_ENV=production
